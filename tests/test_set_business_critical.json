  {
    "id": "bc-007",
    "question": "What percentage of batch rooms are at full capacity?",
    "difficulty": "MEDIUM",
    "category": "percentage",
    "business_critical": true,
    "severity": "P1",
    "intent": "KPI",
    "expected_tables": ["cdp.central.gold_batch_rooms"],
    "expected_metric": "full_capacity_pct",
    "expected_metric_sql": "COUNT(CASE WHEN fill_rate >= 1.0 THEN 1 END) * 100.0 / NULLIF(COUNT(*), 0)",
