      "requires_time_filter": false,
      "requires_metric_match": false,
      "requires_percentage_calc": true,
      "wrong_answer_severity": "high",
      "notes": "Must use conditional count for percentage, not just AVG(fill_rate)."
    },
    "tags": ["capacity", "percentage", "batch-room"]
  },
