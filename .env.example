# RAVEN — Retrieval-Augmented Validated Engine for Natural-language SQL
# https://github.com/aamirpw306/raven

# OpenAI
OPENAI_API_KEY=sk-...

# Trino
TRINO_HOST=your-trino-host
TRINO_PORT=443
TRINO_USER=text2sql_readonly
TRINO_CATALOG=your_catalog
TRINO_SCHEMA=your_schema
TRINO_HTTP_SCHEME=https

# PostgreSQL (pgvector)
PGVECTOR_HOST=localhost
PGVECTOR_PORT=5433
PGVECTOR_DB=raven
PGVECTOR_USER=raven
PGVECTOR_PASSWORD=changeme

# Metabase PostgreSQL (for extracting saved questions)
METABASE_PG_HOST=your-metabase-pg-host
METABASE_PG_PORT=5432
METABASE_PG_DB=metabase
METABASE_PG_USER=readonly
METABASE_PG_PASSWORD=changeme
