# RAVEN — Retrieval-Augmented Validated Engine for Natural-language SQL
# Copy to .env and fill in real values. NEVER commit .env!

# Azure OpenAI
AZURE_OPENAI_API_BASE=https://your-apim-endpoint.azure-api.net/openai-load-balancing
AZURE_OPENAI_API_KEY=REPLACE_ME
AZURE_OPENAI_CHAT_MODEL=gpt4o
AZURE_OPENAI_API_VERSION=2024-03-01-preview

# Direct OpenAI (fallback if Azure vars are empty)
OPENAI_API_KEY=sk-...

# Azure OpenAI Embedding (separate endpoint/deployment)
AZURE_OPENAI_EMBED_ENDPOINT=https://your-embedding-endpoint.openai.azure.com
AZURE_OPENAI_EMBED_KEY=REPLACE_ME
AZURE_OPENAI_EMBED_DEPLOYMENT=embedlarge
AZURE_OPENAI_EMBED_API_VERSION=2023-05-15

# Trino
TRINO_HOST=your-trino-host
TRINO_PORT=443
TRINO_USER=your_user
TRINO_PASSWORD=REPLACE_ME
TRINO_CATALOG=cdp
TRINO_SCHEMA=default
TRINO_HTTP_SCHEME=https
TRINO_SSL_INSECURE=false

# PostgreSQL (pgvector)
PGVECTOR_HOST=your-rds-host.region.rds.amazonaws.com
PGVECTOR_PORT=5432
PGVECTOR_DB=your_db
PGVECTOR_USER=postgres
PGVECTOR_PASSWORD=REPLACE_ME
PGVECTOR_TABLE=son_of_anton_vectors

# Metabase PostgreSQL (for extracting saved questions)
METABASE_PG_HOST=your-metabase-pg-host
METABASE_PG_PORT=5432
METABASE_PG_DB=metabase
METABASE_PG_USER=readonly
METABASE_PG_PASSWORD=REPLACE_ME

# Metabase API (for Focus Mode + Push-to-Metabase)
METABASE_URL=https://metabase-prod.penpencil.co
METABASE_API_KEY=mb_xxxxxxxxxxxxxxxx

# OpenMetadata
OPENMETADATA_URL=https://openmetadata-data.penpencil.co
